export OOODNAKOV_REPO_ROOT="$PWD"
PATH_add "$PWD/scripts"

# Useful when testing bootstrap repeatedly from this repo.
export OOODNAKOV_INTERACTIVE=never

export OOODNAKOV_WEZTERM_WORKSPACE='~/src/ooodnakov-config'
# Machine-local or secret additions stay out of git.
source_env_if_exists .envrc.local

{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.3.1/resources/zpack-schema.json",
  "name": "ooodnakov",
  "version": "1.0.0",
  "description": "Custom glassy island bar for ooodnakov-config",
  "widgets": [
    {
      "name": "ooodnakov",
      "htmlPath": "index.html",
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "presets": [
        {
          "name": "default",
          "anchor": "top_center",
          "offsetX": "0",
          "offsetY": "0",
          "width": "100%",
          "height": "40px",
          "monitorSelection": {
            "type": "all"
          }
        }
      ]
    }
  ]
}

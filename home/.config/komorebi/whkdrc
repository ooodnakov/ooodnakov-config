.shell powershell

# Reload wm stack
lwin + shift + o         : komorebic reload-configuration
lwin + alt + o           : taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden

# WM controls
lwin + q                 : komorebic close
lwin + m                 : komorebic minimize
lwin + shift + space     : komorebic toggle-float
lwin + f                 : komorebic toggle-monocle
lwin + shift + r         : komorebic retile
lwin + i                 : komorebic toggle-shortcuts
lwin + p                 : komorebic toggle-pause

# Scrolling layout controls
lwin + c                 : komorebic change-layout scrolling
lwin + equal             : komorebic scrolling-layout-columns 3
lwin + minus             : komorebic scrolling-layout-columns 1

# Focus windows (shared hjkl model)
lwin + h                 : komorebic focus left
lwin + j                 : komorebic focus down
lwin + k                 : komorebic focus up
lwin + l                 : komorebic focus right

# Move windows
lwin + shift + h         : komorebic move left
lwin + shift + j         : komorebic move down
lwin + shift + k         : komorebic move up
lwin + shift + l         : komorebic move right
lwin + shift + return    : komorebic promote

# Monitor focus/move
lwin + comma             : komorebic cycle-monitor previous
lwin + period            : komorebic cycle-monitor next
lwin + shift + comma     : komorebic cycle-move-to-monitor previous
lwin + shift + period    : komorebic cycle-move-to-monitor next

# Resize
lwin + ctrl + h          : komorebic resize-edge left decrease
lwin + ctrl + j          : komorebic resize-edge down increase
lwin + ctrl + k          : komorebic resize-edge up decrease
lwin + ctrl + l          : komorebic resize-edge right increase

# Workspaces
lwin + 1                 : komorebic focus-workspace 0
lwin + 2                 : komorebic focus-workspace 1
lwin + 3                 : komorebic focus-workspace 2
lwin + 4                 : komorebic focus-workspace 3
lwin + 5                 : komorebic focus-workspace 4
lwin + 6                 : komorebic focus-workspace 5
lwin + 7                 : komorebic focus-workspace 6
lwin + 8                 : komorebic focus-workspace 7

lwin + shift + 1         : komorebic move-to-workspace 0
lwin + shift + 2         : komorebic move-to-workspace 1
lwin + shift + 3         : komorebic move-to-workspace 2
lwin + shift + 4         : komorebic move-to-workspace 3
lwin + shift + 5         : komorebic move-to-workspace 4
lwin + shift + 6         : komorebic move-to-workspace 5
lwin + shift + 7         : komorebic move-to-workspace 6
lwin + shift + 8         : komorebic move-to-workspace 7

lwin + tab               : komorebic cycle-workspace next
lwin + shift + tab       : komorebic cycle-workspace previous

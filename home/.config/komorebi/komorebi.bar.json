{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.40/schema.bar.json",
  "font_family": "MesloLGSDZ Nerd Font Mono",
  "font_size": 14,
  "theme": {
    "palette": "Base16",
    "name": "Ashes",
    "accent": "Base0D"
  },
  "transparency": true,
  "glassy": true,
  "margin": 10,
  "height": 45,
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Update": {
        "enable": true
      }
    },
    {
      "Media": {
        "enable": false
      }
    },
    {
      "Storage": {
        "enable": false
      }
    },
    {
      "Memory": {
        "enable": false
      }
    },
    {
      "Network": {
        "enable": false,
        "show_activity": true,
        "show_total_activity": true
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "󰃭 %a, %b %d"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "󱑒 %H:%M"
      }
    },
    {
      "Battery": {
        "enable": true
      }
    }
  ]
}

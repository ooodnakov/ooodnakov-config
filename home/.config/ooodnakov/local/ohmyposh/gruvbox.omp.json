{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "foreground": "#665c54",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}\u256d\u2500{{ end }}",
          "type": "text"
        },
        {
          "background": "#3c3836",
          "foreground": "#ebdbb2",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }} {{ .Icon }} {{ end }}",
          "type": "os"
        },
        {
          "background": "#3c3836",
          "foreground": "#83a598",
          "style": "plain",
          "template": "<#928374>\u2502</> {{ if eq .Env.OOOCONF_PROMPT_STYLE \"concise\" }}{{ .Folder }}{{ else }}{{ .Path }}{{ end }} ",
          "properties": {
            "style": "full",
            "home_icon": "\uf015 ~",
            "folder_icon": "\uf07c"
          },
          "type": "path"
        },
        {
          "background": "#3c3836",
          "foreground": "#b8bb26",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fabd2f{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#928374>\u2502 </>{{ .HEAD }}{{ if gt .Ahead 0 }} \uf062 {{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} \uf063{{ .Behind }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "transparent",
          "foreground": "#3c3836",
          "style": "plain",
          "template": "\ue0b0",
          "type": "text"
        }
      ]
    },
    {
      "alignment": "right",
      "filler": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#665c54>\u00b7</>{{ end }}",
      "type": "prompt",
      "segments": [
        {
          "background": "transparent",
          "foreground": "#3c3836",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}\ue0b2{{ end }}",
          "type": "text"
        },
        {
          "background": "#3c3836",
          "foreground": "#fb4934",
          "foreground_templates": [
            "{{ if eq .Code 0 }}#b8bb26{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }} ",
          "type": "status"
        },
        {
          "background": "#3c3836",
          "foreground": "#a89984",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#928374>\u2502</> {{ .FormattedMs }}\uf252 {{ end }}",
          "type": "executiontime"
        },
        {
          "background": "#3c3836",
          "foreground": "#fabd2f",
          "style": "plain",
          "template": "{{ if and (ne .Env.OOOCONF_PROMPT_STYLE \"concise\") .Env.DIRENV_FILE }}<#928374>\u2502</> \u25bc {{ end }}",
          "type": "text"
        },
        {
          "background": "#3c3836",
          "foreground": "#8ec07c",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}{{ if .Venv }}<#928374>\u2502</> \ue235 {{ .Venv }} {{ end }}{{ end }}",
          "type": "python",
          "properties": {
            "display_mode": "context",
            "fetch_virtual_env": true
          }
        },
        {
          "background": "#3c3836",
          "foreground": "#83a598",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#928374>\u2502</> <#a89984>at </>{{ .CurrentDate | date \"15:04:05\" }} \uf017 {{ end }}",
          "type": "time"
        },
        {
          "foreground": "#665c54",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }} \u2500\u256e {{ end }}",
          "type": "text"
        }
      ]
    },
    {
      "alignment": "left",
      "type": "prompt",
      "newline": true,
      "segments": [
        {
          "foreground": "#665c54",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}\u2570\u2500{{ end }}",
          "type": "text"
        },
        {
          "foreground": "#b8bb26",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#fb4934{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ]
    },
    {
      "alignment": "right",
      "type": "rprompt",
      "segments": [
        {
          "foreground": "#665c54",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}\u2500\u256f {{ end }}",
          "type": "text"
        }
      ]
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": false,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#b8bb26",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#fb4934{{ end }}"
    ],
    "template": "\u276f "
  },
  "version": 3
}

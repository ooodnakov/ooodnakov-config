# Local-only shell variables.
# This file is intentionally not sourced from the repo copy.
# Copy it to ~/.config/ooodnakov/local/env.zsh and edit there.
#
# Alternatively, use the LOCAL OVERRIDES section inside the synced
# ~/.config/ooodnakov/local/env.zsh — lines between the START/END
# markers survive `oooconf secrets sync`.

# export GITHUB_TOKEN="replace-me"
# export WORK_MACHINE_NAME="replace-me"
# export CODEX_HOME="/path/to/.codex"
# export PATH="$HOME/.config/ezsh/bin:$PATH"
# export GOPATH="$HOME/go"

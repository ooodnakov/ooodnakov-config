#!/usr/bin/env bash
set -euo pipefail

resolve_self() {
  local source="$1"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done
  cd "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_self "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../../.." && pwd)"

exec env OOODNAKOV_REPO_ROOT="$REPO_ROOT" "$REPO_ROOT/scripts/ooodnakov.sh" "$@"

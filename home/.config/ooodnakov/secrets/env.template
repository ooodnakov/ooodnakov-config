# Secrets template for `oooconf secrets sync`.
# Keep this file in git with secret references or non-secret shared values only.
# For Bitwarden CLI, use:
# - bw://item/<item-id>/password
# - bw://item/<item-id>/username
# - bw://item/<item-id>/notes
# - bw://item/<item-id>/uri
# - bw://item/<item-id>/field/<field-name>

HAPPY_SERVER_URL=https://happy.ooodnakov.ru
GITHUB_TOKEN=bw://item/replace-with-github-item-id/password
OPENAI_API_KEY=bw://item/replace-with-openai-item-id/password
BRAVE_API_KEY=bw://item/replace-with-brave-item-id/password

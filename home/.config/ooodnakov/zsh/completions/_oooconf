_oooconf_main() {
  local context state line
  typeset -A opt_args
  _arguments -C \
    '-C[set repo root path]:value:_files -/' \
    '--repo-root[set repo root path]:value:_files -/' \
    '--print-repo-root[print resolved repo root]' \
    '-h[show help]' \
    '--help[show help]' \
    '-n[preview actions without changing files]' \
    '--dry-run[preview actions without changing files]' \
    '--yes-optional[auto-confirm optional dependency installs]' \
    '-V[show version]' \
    '--version[show version]' \
    '1:command:->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe -t commands 'oooconf command' _oooconf_commands
      ;;
    args)
      local command_name i
      for (( i = 2; i < CURRENT; i++ )); do
        case "$words[i]" in
          -C|--repo-root) (( i++ )) ;;
          -*) ;;
          *) command_name="$words[i]"; break ;;
        esac
      done
      case $command_name in
        bootstrap) _oooconf_bootstrap ;;
        install) _oooconf_install ;;
        deps) _oooconf_deps ;;
        update) _oooconf_update ;;
        doctor) _oooconf_doctor ;;
        dry-run) _oooconf_dry_run ;;
        delete) _oooconf_delete ;;
        remove) _oooconf_remove ;;
        lock) _oooconf_lock ;;
        update-pins) _oooconf_update_pins ;;
        completions) _oooconf_completions ;;
        agents) _oooconf_agents ;;
        secrets) _oooconf_secrets ;;
        shell) _oooconf_shell ;;
        color) _oooconf_color ;;
        version) _oooconf_version ;;
        check) _oooconf_doctor ;;
        preview) _oooconf_dry_run ;;
        upgrade) _oooconf_update ;;
        komorebi) _oooconf_komorebi ;;
        wm) _oooconf_wm ;;
        help) _oooconf_help ;;
        minimal) _oooconf_minimal ;;
      esac
      ;;
  esac
}

_oooconf_main "$@"

#compdef oooconf o

local -a oooconf_commands global_opts setup_opts deps_keys agents_subcommands agents_opts secrets_subcommands shell_subcommands shell_forgit_alias_modes shell_typo_modes shell_psfzf_modes shell_auto_uv_modes
local command_name secrets_command shell_command
local i

oooconf_commands=(
  'bootstrap:clone or update the repo, then run install'
  'install:apply managed config'
  'deps:install optional dependencies only'
  'update:update the repo, then re-run install'
  'doctor:validate managed links and tools'
  'dry-run:preview install without changes'
  'delete:remove managed links and restore backups'
  'remove:remove managed links only'
  'lock:regenerate dependency lock artifacts'
  'update-pins:check or update pinned refs'
  'completions:regenerate tracked completion files'
  'agents:detect/sync/doctor/update AGENTS.md policy blocks'
  'secrets:sync or validate local secret env files'
  'shell:manage local shell preferences'
  'version:show version information'
  'check:alias for doctor'
  'preview:alias for dry-run'
  'upgrade:alias for update'
  'komorebi:command'
  'wm:command'
  'help:show help'
)

global_opts=(
  '-C:run against a specific repo checkout:_files -/'
  '--repo-root:run against a specific repo checkout:_files -/'
  '--print-repo-root:print the resolved repo root'
  '-h:show help'
  '--help:show help'
  '-n:add --dry-run to install or update'
  '--dry-run:add --dry-run to install or update'
  '--yes-optional:auto-accept optional dependency installs'
  '-V:show version information'
  '--version:show version information'
)

setup_opts=(
  '--dry-run:preview actions without changing the filesystem'
  '--yes-optional:auto-accept optional dependency installs'
  '-h:show setup help'
  '--help:show setup help'
)

deps_keys=(
  'wget:downloading auxiliary assets and parity with ezsh tooling'
  'git:Git version control'
  'wezterm:WezTerm terminal'
  'oh-my-posh:Oh My Posh prompt'
  'posh-git:PowerShell Git completions and shell integration'
  'psfzf:PowerShell fzf integration for history, files, and tab completion'
  'choco:Chocolatey package manager (Windows)'
  'gsudo:gsudo elevation helper (Windows)'
  'rg:ripgrep search tool'
  'fd:fd find alternative'
  'zsh:default shell support'
  'direnv:direnv shell integration'
  'fzf:fzf shell integration'
  'bat:cat alternative with syntax highlighting'
  'delta:Git diff pager with syntax highlighting'
  'glow:terminal Markdown reader'
  'gum:interactive terminal UI toolkit for selectors and prompts'
  'zoxide:smart directory jumping with z/zi'
  'q:q text-as-data CLI'
  'eza:modern ls aliases'
  'yazi:terminal file manager'
  'ffmpeg:media preview backend for yazi'
  'jq:JSON parsing helper for yazi plugins'
  'p7zip:archive preview and extraction for yazi'
  'poppler:PDF preview support for yazi'
  'fc-cache:refreshing installed font caches'
  'cargo:Rust package manager via rustup'
  'dua:disk usage analysis via dua-cli'
  'nvim:Neovim runtime for LazyVim'
  'tree-sitter:Tree-sitter CLI for parser development and highlighting'
  'k:standalone k command'
  'python3:Python runtime and helper scripts'
  'lazygit:simple terminal UI for git commands'
  'uv:Python package manager via official installer'
  'bw:Bitwarden CLI via official native archive'
  'rtk:token-optimized command proxy for AI CLI workflows'
  'imagemagick:Image processing library (required by Snacks.image)'
  'ghostscript:PostScript and PDF interpreter (required by Snacks.image for PDFs)'
  'luarocks:Package manager for Lua modules'
  'tectonic:Modern LaTeX engine (required by Snacks.image for LaTeX)'
  'mermaid-cli:Command-line interface for Mermaid (required by Snacks.image for diagrams)'
  'zig:Zig compiler (recommended C compiler for nvim-treesitter on Windows)'
  'neovim-node:Neovim provider for Node.js plugins'
  'neovim-python:Neovim provider for Python plugins'
  'fastfetch:system information tool'
  'btop:system information tool'
  'glazewm:Tiling window manager for Windows'
  'zebar:Modern, customizable status bar for Windows'
)

agents_subcommands=(
  'detect:detect configured agent CLIs on PATH'
  'sync:append or update shared AGENTS.md block'
  'doctor:verify AGENTS.md shared block is current'
  'update:update installed agent CLIs'
)

agents_opts=(
  '--repo-root:repo root containing oooconf agent config:_files -/'
  '--config:override agent config JSON path:_files'
)

secrets_subcommands=(
  'login:login'
  'unlock:unlock'
  'sync:sync'
  'doctor:doctor'
  'list:list'
  'ls:ls'
  'status:status'
  'logout:logout'
  'add:add'
  'remove:remove'
  'rm:rm'
  'del:del'
)

shell_subcommands=(
  'status:status'
  'forgit-aliases:forgit-aliases'
  'typo-handling:typo-handling'
  'psfzf-tab:psfzf-tab'
  'psfzf-git:psfzf-git'
  'auto-uv-env:auto-uv-env'
)

shell_forgit_alias_modes=(
  'plain:plain'
  'forgit:forgit'
  'status:status'
)
shell_typo_modes=(
  'silent:silent'
  'suggest:suggest'
  'help:help'
  'status:status'
)
shell_psfzf_modes=(
  'enabled:enabled'
  'disabled:disabled'
  'status:status'
)
shell_auto_uv_modes=(
  'enabled:enabled'
  'quiet:quiet'
  'status:status'
)

command_name=
for (( i = 2; i < CURRENT; i++ )); do
  case "$words[i]" in
    -C|--repo-root)
      (( i++ ))
      ;;
    -*)
      ;;
    bootstrap|install|deps|update|doctor|dry-run|delete|remove|lock|update-pins|completions|agents|secrets|shell|version|check|preview|upgrade|komorebi|wm|help)
      command_name="$words[i]"
      break
      ;;
  esac
done

if [[ -z "$command_name" ]]; then
  _describe -t commands 'oooconf command' oooconf_commands && return 0
  _describe -t options 'oooconf option' global_opts && return 0
  return 0
fi

case "$command_name" in
  upgrade)
    command_name=update
    ;;
  check)
    command_name=doctor
    ;;
  preview)
    command_name=dry-run
    ;;
esac

case "$command_name" in
  help)
    _describe -t commands 'oooconf command' oooconf_commands && return 0
    ;;
  install|update|deps)
    _describe -t options 'oooconf option' setup_opts
    _describe -t dependencies 'dependency key' deps_keys
    return 0
    ;;
  completions)
    _describe -t options 'oooconf completions option' '--dry-run:preview generation actions'
    return 0
    ;;
  update-pins)
    _describe -t options 'oooconf update-pins option' '--apply:write updated pins and lock artifacts'
    return 0
    ;;
  agents)
    local agents_command
    agents_command=
    for (( i = 3; i < CURRENT; i++ )); do
      case "$words[i]" in
        detect|sync|doctor|update)
          agents_command="$words[i]"
          break
          ;;
      esac
    done

    if [[ -z "$agents_command" ]]; then
      _describe -t agents-subcommands 'oooconf agents command' agents_subcommands && return 0
      return 0
    fi

    case "$agents_command" in
      detect)
        _describe -t options 'oooconf agents detect option' $agents_opts '--json:emit machine-readable JSON output'
        ;;
      sync|update)
        _describe -t options "oooconf agents $agents_command option" $agents_opts '--check:validate only; do not write files'
        ;;
      doctor)
        _describe -t options 'oooconf agents doctor option' $agents_opts '--strict-config-paths:fail if no default config path exists for a target'
        ;;
    esac
    return 0
    ;;
  shell)
    shell_command=
    for (( i = 3; i < CURRENT; i++ )); do
      case "$words[i]" in
        status|forgit-aliases|typo-handling|psfzf-tab|psfzf-git|auto-uv-env)
          shell_command="$words[i]"
          break
          ;;
      esac
    done

    if [[ -z "$shell_command" ]]; then
      _describe -t shell-subcommands 'oooconf shell command' shell_subcommands && return 0
      return 0
    fi

    case "$shell_command" in
      forgit-aliases)
        _describe -t modes 'forgit alias mode' shell_forgit_alias_modes
        ;;
      typo-handling)
        _describe -t modes 'typo handling mode' shell_typo_modes
        ;;
      psfzf-tab|psfzf-git)
        _describe -t modes 'PSFzf mode' shell_psfzf_modes
        ;;
      auto-uv-env)
        _describe -t modes 'auto-uv-env mode' shell_auto_uv_modes
        ;;
      status)
        return 0
        ;;
    esac
    return 0
    ;;
  secrets)
    secrets_command=
    for (( i = 3; i < CURRENT; i++ )); do
      case "$words[i]" in
        login|unlock|sync|doctor|list|ls|status|logout|add|remove|rm|del)
          secrets_command="$words[i]"
          break
          ;;
      esac
    done

    if [[ -z "$secrets_command" ]]; then
      _describe -t secrets-subcommands 'oooconf secrets command' secrets_subcommands && return 0
      return 0
    fi

    case "$secrets_command" in
      ls)
        secrets_command=list
        ;;
      rm|del)
        secrets_command=remove
        ;;
    esac

    case "$secrets_command" in
      sync)
        _describe -t options 'oooconf secrets sync option' '--backend:secret backend to use:(bw)' '--template:override the tracked template path:_files' '--dry-run:preview the sync without writing files' '--force:rewrite generated files even when unchanged'
        ;;
      doctor)
        _describe -t options 'oooconf secrets doctor option' '--backend:secret backend to use:(bw)' '--template:override the tracked template path:_files'
        ;;
      list)
        _describe -t options 'oooconf secrets list option' '--template:override the tracked template path:_files' '--resolved:resolve bw:// references (requires unlocked BW_SESSION)' '--backend:secret backend to use:(bw)'
        ;;
      status)
        _describe -t options 'oooconf secrets status option' '--template:override the tracked template path:_files'
        ;;
      login)
        _describe -t options 'oooconf secrets login option' '--server:Bitwarden or Vaultwarden server URL:' '--method:login method:(auto password apikey)' '--client-id:Bitwarden API key client ID:' '--client-secret:Bitwarden API key client secret:'
        ;;
      unlock)
        _describe -t options 'oooconf secrets unlock option' '--shell:shell syntax to emit:(sh zsh bash pwsh)' '--raw:print only the unlocked session token'
        ;;
      add|remove)
        _describe -t options "oooconf secrets $secrets_command option" '--template:override the tracked template path:_files'
        ;;
      logout)
        return 0
        ;;
    esac
    return 0
    ;;
  dry-run|doctor|delete|remove|lock|version|bootstrap)
    return 0
    ;;
esac

return 0

#compdef oooconf

local curcontext="$curcontext" state line
typeset -A opt_args

local -a commands global_opts setup_opts deps_args update_pins_opts secrets_common_opts
local command_name secrets_command
commands=(
  'bootstrap:clone or update the repo, then run install'
  'install:apply managed config'
  'deps:install optional dependencies only'
  'update:update the repo, then re-run install'
  'doctor:validate managed links and tools'
  'dry-run:preview install without changes'
  'delete:remove managed links and restore backups'
  'remove:remove managed links only'
  'lock:regenerate dependency lock artifacts'
  'update-pins:check or update pinned refs'
  'secrets:sync or validate local secret env files'
  'help:show help'
  'version:show version information'
)

global_opts=(
  '(-C --repo-root)'{-C,--repo-root}'[run against a specific repo checkout]:repo root:_files -/'
  '--print-repo-root[print the resolved repo root]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-n --dry-run)'{-n,--dry-run}'[add --dry-run to install or update]'
  '--yes-optional[auto-accept optional dependency installs]'
  '(-V --version)'{-V,--version}'[show version information]'
)

setup_opts=(
  '--dry-run[preview actions without changing the filesystem]'
  '--yes-optional[auto-accept optional dependency installs]'
  '(-h --help)'{-h,--help}'[show setup help]'
)

deps_args=(
  '--dry-run[preview dependency installation without changing the filesystem]'
  '--yes-optional[auto-accept optional dependency installs]'
  '(-h --help)'{-h,--help}'[show deps help]'
  '*:dependency key:((wget\:"download helpers and ezsh parity" zsh\:"default shell support" direnv\:"direnv shell integration" fzf\:"fzf shell integration" bat\:"cat alternative with syntax highlighting" delta\:"Git diff pager with syntax highlighting" glow\:"terminal Markdown reader" gum\:"interactive terminal UI toolkit" zoxide\:"smart directory jumping" q\:"q text-as-data CLI" eza\:"modern ls aliases" uv\:"Python package manager" bw\:"Bitwarden CLI" node\:"Node.js runtime" npm\:"Node package manager" pnpm\:"pnpm package manager" autoconf\:"build optional ezsh native components" fc-cache\:"refresh installed font caches" cargo\:"Rust package manager" dua\:"disk usage analysis via dua-cli" nvim\:"Neovim for LazyVim" k\:"standalone k command" python3\:"Python runtime and helper scripts"))'
)

update_pins_opts=(
  '--apply[write updated pinned refs before regenerating lock artifacts]'
)

secrets_common_opts=(
  '--backend[secret backend to use]:backend:(bw)'
  '--template[override the tracked template path]:template:_files'
)

_arguments -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && return 0

case "$state" in
  command)
    _describe -t commands 'oooconf command' commands
    ;;
  args)
    command_name=
    for (( i = 1; i <= CURRENT; i++ )); do
      case "$words[i]" in
        bootstrap|install|deps|update|doctor|dry-run|delete|remove|lock|update-pins|secrets|help|version)
          command_name="$words[i]"
          break
          ;;
      esac
    done

    case "$command_name" in
      help)
        _describe -t commands 'oooconf command' commands
        ;;
      install|update)
        _arguments $setup_opts
        ;;
      deps)
        _arguments $deps_args
        ;;
      dry-run|doctor|delete|remove|lock|version)
        _message 'no additional arguments'
        ;;
      update-pins)
        _arguments $update_pins_opts
        ;;
      secrets)
        secrets_command=
        for (( i = 1; i <= CURRENT; i++ )); do
          case "$words[i]" in
            login|unlock|sync|doctor)
              secrets_command="$words[i]"
              break
              ;;
          esac
        done

        if [[ -z "$secrets_command" ]]; then
          _describe -t secrets-subcommands 'oooconf secrets command' \
            'login:configure Bitwarden server and start login' \
            'unlock:print shell code for BW_SESSION after unlocking Bitwarden' \
            'sync:render local secret env files' \
            'doctor:validate local secret env files and backend tooling'
        else
          case "$secrets_command" in
            sync)
              _arguments \
                $secrets_common_opts \
                '--dry-run[preview the sync without writing files]' \
                '--force[rewrite generated files even when unchanged]'
              ;;
            doctor)
              _arguments $secrets_common_opts
              ;;
            login)
              _arguments '--server[Bitwarden or Vaultwarden server URL]:server: '
              ;;
            unlock)
              _arguments \
                '--shell[shell syntax to emit]:shell:(sh zsh bash pwsh)' \
                '--raw[print only the unlocked session token]'
              ;;
            *)
              _describe -t secrets-subcommands 'oooconf secrets command' \
                'login:configure Bitwarden server and start login' \
                'unlock:print shell code for BW_SESSION after unlocking Bitwarden' \
                'sync:render local secret env files' \
                'doctor:validate local secret env files and backend tooling'
              ;;
          esac
        fi
        ;;
      bootstrap)
        _message 'environment variables configure bootstrap behavior'
        ;;
      *)
        ;;
    esac
    ;;
esac

            ;;
          reload)
            child_name=reload
            words=("${(@)words[i,-1]}")
            CURRENT=$(( CURRENT - i + 1 ))
            _oooconf_wm_bar_reload
            return
            ;;
        esac
      done
      ;;
  esac
}


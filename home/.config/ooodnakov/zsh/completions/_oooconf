command_name=
for (( i = 2; i < CURRENT; i++ )); do
  case "$words[i]" in
    -C|--repo-root)
      (( i++ ))
      ;;
    -*)
      ;;
    bootstrap|install|deps|update|doctor|dry-run|delete|remove|lock|update-pins|completions|agents|secrets|shell|color|version|check|preview|upgrade|komorebi|wm|help)
      command_name="$words[i]"
      break
      ;;
  esac
done

if [[ -z "$command_name" ]]; then
  _describe -t commands 'oooconf command' oooconf_commands && return 0
  _describe -t options 'oooconf option' global_opts && return 0
  return 0
fi

if [[ -n "${oooconf_aliases[$command_name]:-}" ]]; then
  command_name="${oooconf_aliases[$command_name]}"
fi

safe_command="${command_name//[^A-Za-z0-9_]/_}"
if [[ "$safe_command" =~ ^[0-9] ]]; then safe_command="_$safe_command"; fi
local var_opts="cmd_${safe_command}_options"
local -a command_options=("${(@P)var_opts}")
local var_subs="cmd_${safe_command}_subcommands"
local -a command_subcommands=("${(@P)var_subs}")
local var_cmd_values="cmd_${safe_command}_values"
local -a command_values=("${(@P)var_cmd_values}")

subcommand_name=
for (( i = 3; i < CURRENT; i++ )); do
  case "$words[i]" in
    -*) ;;
    *)
      local candidate="$words[i]"
      if (( ${command_subcommands[(Ie)$candidate]} )); then
        subcommand_name="$candidate"
        break
      fi
      ;;
  esac
done

previous_token=
if (( CURRENT > 2 )); then previous_token="$words[CURRENT-1]"; fi

if [[ -z "$subcommand_name" ]]; then
  if [[ "$command_name" == help ]]; then
    _describe -t commands 'oooconf command' oooconf_commands
    return 0
  fi
  _describe -t subcommands 'oooconf subcommand' command_subcommands
  _describe -t options 'oooconf option' command_options
  _describe -t values 'oooconf value' command_values
  if [[ "$command_name" == install || "$command_name" == deps || "$command_name" == update ]]; then
    _describe -t dependencies 'dependency key' deps_keys
  fi
  return 0
fi

safe_subcommand="${subcommand_name//[^A-Za-z0-9_]/_}"
if [[ "$safe_subcommand" =~ ^[0-9] ]]; then safe_subcommand="_$safe_subcommand"; fi
local var_sub_opts="cmd_${safe_command}_${safe_subcommand}_options"
local -a sub_options=("${(@P)var_sub_opts}")
local var_sub_vals="cmd_${safe_command}_${safe_subcommand}_values"
local -a sub_values=("${(@P)var_sub_vals}")
local var_sub_subs="cmd_${safe_command}_${safe_subcommand}_subsubcommands"
local -a sub_subcommands=("${(@P)var_sub_subs}")
local var_opt_vals="cmd_${safe_command}_option_values"
local -a option_value_entries=("${(@P)var_opt_vals}")

subsubcommand_name=
for (( i = 4; i < CURRENT; i++ )); do
  case "$words[i]" in
    -*) ;;
    *)
      local candidate="$words[i]"
      if (( ${sub_subcommands[(Ie)$candidate]} )); then
        subsubcommand_name="$candidate"
        break
      fi
      ;;
  esac
done

local option_entry
for option_entry in "${option_value_entries[@]}"; do
  local opt_name="${option_entry%%:*}"
  local opt_values="${option_entry#*:}"
  if [[ "$previous_token" == "$opt_name" ]]; then
    _values "$opt_name value" ${(z)opt_values}
    return 0
  fi
done

if [[ -z "$subsubcommand_name" ]]; then
  _describe -t options 'oooconf subcommand option' sub_options
  _describe -t values 'oooconf subcommand value' sub_values
  _describe -t subsubcommands 'oooconf subsubcommand' sub_subcommands
  return 0
fi

safe_subsubcommand="${subsubcommand_name//[^A-Za-z0-9_]/_}"
if [[ "$safe_subsubcommand" =~ ^[0-9] ]]; then safe_subsubcommand="_$safe_subsubcommand"; fi
local var_subsub_opts="cmd_${safe_command}_${safe_subcommand}_${safe_subsubcommand}_options"
local -a subsub_options=("${(@P)var_subsub_opts}")
_describe -t options 'oooconf subsubcommand option' subsub_options
return 0

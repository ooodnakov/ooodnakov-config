{
  "mcp_servers": {
    "playwright": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@playwright/mcp@latest"
      ],
      "description": "headless browser automation and web testing"
    },
    "context7": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@upstash/context7-mcp",
        "--api-key",
        "{CONTEXT7_API_KEY}"
      ],
      "env_vars": [
        "CONTEXT7_API_KEY"
      ],
      "description": "documentation search and code examples for thousands of libraries"
    },
    "github": {
      "command": "pnpm",
      "args": [
        "dlx",
        "@modelcontextprotocol/server-github"
      ],
      "description": "GitHub API access (repositories, issues, PRs)"
    },
    "ssh-mcp-openwrt": {
      "command": "pnpm",
      "args": [
        "dlx",
        "ssh-mcp",
        "-y",
        "--",
        "--host=192.168.1.1",
        "--user=root",
        "--timeout=30000",
        "--maxChars=none"
      ]
    },
    "ssh-mcp-orange": {
      "command": "pnpm",
      "args": [
        "dlx",
        "ssh-mcp",
        "-y",
        "--",
        "--host=192.168.1.201",
        "--user=rem",
        "--timeout=30000",
        "--maxChars=none"
      ]
    }
  },
  "skills": [
  ],
  "skill_specs": [
  ]
}

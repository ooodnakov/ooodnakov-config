{
  "mcp_servers": {
    "context7": {
      "args": [
        "dlx",
        "@upstash/context7-mcp",
        "--api-key",
        "{CONTEXT7_API_KEY}"
      ],
      "command": "pnpm",
      "description": "documentation search and code examples for thousands of libraries",
      "env_vars": [
        "CONTEXT7_API_KEY"
      ]
    },
    "github": {
      "args": [
        "dlx",
        "@modelcontextprotocol/server-github"
      ],
      "command": "pnpm",
      "description": "GitHub API access (repositories, issues, PRs)"
    },
    "playwright": {
      "args": [
        "dlx",
        "@playwright/mcp@latest"
      ],
      "command": "pnpm",
      "description": "headless browser automation and web testing"
    },
    "ssh-mcp-openwrt": {
      "args": [
        "dlx",
        "ssh-mcp",
        "-y",
        "--",
        "--host=192.168.1.1",
        "--user=root",
        "--timeout=30000",
        "--maxChars=none"
      ],
      "command": "pnpm"
    },
    "ssh-mcp-orange": {
      "args": [
        "dlx",
        "ssh-mcp",
        "-y",
        "--",
        "--host=192.168.1.201",
        "--user=rem",
        "--timeout=30000",
        "--maxChars=none"
      ],
      "command": "pnpm"
    }
  },
  "skill_specs": [
    {
      "agent": "gemini",
      "description": "Added via oooconf agents skills add (context7)",
      "name": "context7",
      "source": "https://github.com/context7"
    }
  ],
  "skills": [
    "context7 (gemini)"
  ]
}

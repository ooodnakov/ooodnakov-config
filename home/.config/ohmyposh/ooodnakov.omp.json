{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "foreground": "#6c6c6c",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}╭─{{ end }}",
          "type": "text"
        },
        {
          "background": "#444444",
          "foreground": "#eeeeee",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }} {{ .Icon }} {{ end }}",
          "type": "os"
        },
        {
          "background": "#444444",
          "foreground": "#0087af",
          "style": "plain",
          "template": "<#949494>│</> {{ if eq .Env.OOOCONF_PROMPT_STYLE \"concise\" }}{{ .Folder }}{{ else }}{{ .Path }}{{ end }} ",
          "properties": {
            "style": "full",
            "home_icon": " ~",
            "folder_icon": ""
          },
          "type": "path"
        },
        {
          "background": "#444444",
          "foreground": "#5fdf00",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#dfaf00{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#949494>│ </>{{ .HEAD }}{{ if gt .Ahead 0 }}  {{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} {{ .Behind }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "transparent",
          "foreground": "#444444",
          "style": "plain",
          "template": "",
          "type": "text"
        }
      ]
    },
    {
      "alignment": "right",
      "filler": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#6c6c6c>·</>{{ end }}",
      "type": "prompt",
      "segments": [
        {
          "background": "transparent",
          "foreground": "#444444",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}{{ end }}",
          "type": "text"
        },
        {
          "background": "#444444",
          "foreground": "#d70000",
          "foreground_templates": [
            "{{ if eq .Code 0 }}#5faf00{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " {{ if gt .Code 0 }}{{ else }}{{ end }} ",
          "type": "status"
        },
        {
          "background": "#444444",
          "foreground": "#a8a8a8",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#949494>│</> {{ .FormattedMs }} {{ end }}",
          "type": "executiontime"
        },
        {
          "background": "#444444",
          "foreground": "#dfaf00",
          "style": "plain",
          "template": "{{ if and (ne .Env.OOOCONF_PROMPT_STYLE \"concise\") .Env.DIRENV_FILE }}<#949494>│</> ▼ {{ end }}",
          "type": "text"
        },
        {
          "background": "#444444",
          "foreground": "#00afaf",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}{{ if .Venv }}<#949494>│</>  {{ .Venv }} {{ end }}{{ end }}",
          "type": "python",
          "properties": {
            "display_mode": "context",
            "fetch_virtual_env": true
          }
        },
        {
          "background": "#444444",
          "foreground": "#5f8787",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}<#949494>│</> <#a8a8a8>at </>{{ .CurrentDate | date \"15:04:05\" }}  {{ end }}",
          "type": "time"
        },
        {
          "foreground": "#6c6c6c",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }} ─╮ {{ end }}",
          "type": "text"
        }
      ]
    },
    {
      "alignment": "left",
      "type": "prompt",
      "newline": true,
      "segments": [
        {
          "foreground": "#6c6c6c",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}╰─{{ end }}",
          "type": "text"
        },
        {
          "foreground": "#5fdf00",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff0000{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "❯ ",
          "type": "status"
        }
      ]
    },
    {
      "alignment": "right",
      "type": "rprompt",
      "segments": [
        {
          "foreground": "#6c6c6c",
          "style": "plain",
          "template": "{{ if ne .Env.OOOCONF_PROMPT_STYLE \"concise\" }}─╯ {{ end }}",
          "type": "text"
        }
      ]
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": false,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#5fdf00",
    "foreground_templates": [
      "{{ if gt .Code 0 }}#ff0000{{ end }}"
    ],
    "template": "❯ "
  },
  "version": 3
}
